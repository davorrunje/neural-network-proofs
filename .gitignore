# Lean/Lake build artifacts and downloaded dependencies
.lake/

# Subagent-driven-development working directory (scratch, not part of the project)
.superpowers/

# Per-user local Claude Code overrides (machine-specific; not shared).
# The shared, committed config lives in .claude/settings.json.
.claude/settings.local.json

# Repo-local Python venv for the blueprint toolchain (created by scripts/setup-dev.sh)
.venv/

# leanblueprint build artifacts (generated by `leanblueprint web`/`pdf`)
blueprint/web/
blueprint/print/
blueprint/lean_decls
blueprint/src/*.aux
blueprint/src/*.log
blueprint/src/*.out
blueprint/src/*.pdf
blueprint/src/*.paux
blueprint/src/*.pdfpc

# Vibe config generated at container provisioning time (gen-vibe-config.sh)
.vibe/
